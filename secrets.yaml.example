# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — never commit real credentials.

# Home location (used by HA for sun/weather)
home_latitude: "35.6762"
home_longitude: "139.6503"
home_elevation: "40"

# SwitchBot
switchbot_api_key: "YOUR_SWITCHBOT_API_KEY"
switchbot_secret_key: "YOUR_SWITCHBOT_SECRET_KEY"

# Ring
ring_username: "your@email.com"
ring_password: "YOUR_RING_PASSWORD"

# Eufy Security (via HACS eufy_security integration)
eufy_username: "your@email.com"
eufy_password: "YOUR_EUFY_PASSWORD"

# Alexa Media Player (via HACS)
alexa_email: "your@amazon.com"
alexa_password: "YOUR_AMAZON_PASSWORD"
